# Copy this file to .env and set secure passwords in production.

# Database
POSTGRES_PASSWORD=change_this_to_a_secure_database_password
# Note: The database_url must match the POSTGRES parameters from docker-compose.yml
SENTINEL_DATABASE_URL=postgresql+asyncpg://sentinel_db_user:change_this_to_a_secure_database_password@postgres:5432/sentinel_db  # pragma: allowlist secret

# Sentinel API
SENTINEL_API_KEY=change_this_to_a_secure_bearer_token  # pragma: allowlist secret

# Grafana
GRAFANA_ADMIN_PASSWORD=change_this_to_a_secure_grafana_password
