# Sentinel-Linux 2.0 — environment template.
# Copy to `.env` (which is git-ignored) and fill in real values.
# All variables are loaded by `sentinel.settings.Settings` with strict validation.

# --- Required --------------------------------------------------------------

# Deployment environment. One of: development | test | production.
# No default — startup fails fast if unset.
SENTINEL_ENV=development

# --- Optional (defaults shown) --------------------------------------------

# Log level. One of: DEBUG | INFO | WARNING | ERROR | CRITICAL.
SENTINEL_LOG_LEVEL=INFO

# Log format. One of: json | console. Use json in production for SIEM ingest.
SENTINEL_LOG_FORMAT=json

# --- Reserved for later phases (do not set yet) ---------------------------
# SENTINEL_DB_URL=postgresql+asyncpg://user:pass@host/sentinel   # Phase 6
# SENTINEL_API_KEY=replace-me                                    # Phase 6
# SENTINEL_WEBHOOK_URL=https://hooks.example.com/sentinel        # Phase 5
# SENTINEL_WEBHOOK_HMAC_SECRET=replace-me                        # Phase 5
# SENTINEL_SMTP_HOST=smtp.example.com                            # Phase 5
# SENTINEL_SMTP_PORT=587                                         # Phase 5
# SENTINEL_SMTP_USER=replace-me                                  # Phase 5
# SENTINEL_SMTP_PASSWORD=replace-me                              # Phase 5
